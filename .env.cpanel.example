# Welwitschia ERP — .env para cPanel (us168) — PostgreSQL + sem Redis/Node.
# Copiar para .env no servidor e preencher os valores reais.

APP_NAME="Welwitschia ERP"
APP_ENV=production
APP_DEBUG=false
APP_KEY=                       # gerar: php artisan key:generate
APP_URL=https://welwitschia.ao
APP_TIMEZONE=Africa/Luanda
APP_LOCALE=pt

# --- PostgreSQL (criado no cPanel → PostgreSQL Databases) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=welwitschia_landlord     # nome final que o cPanel mostrar
DB_USERNAME=welwitschia_user         # utilizador criado no cPanel
DB_PASSWORD=                         # password do utilizador

# --- Sem Redis: tudo em ficheiro/BD ---
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync                # processa em linha (pilot); sem Horizon/cron

# Domínio único (sem wildcard)
CENTRAL_DOMAINS="welwitschia.ao,www.welwitschia.ao"
TENANT_BASE_DOMAIN=welwitschia.ao

# ProxyPay / TelcoSMS (por empresa, configurados na app)
# AGT Facturação Eletrónica
AGT_FE_BASE_URL=https://sifphml.minfin.gov.ao/sigt/fe/v1
AGT_FE_USERNAME=
AGT_FE_PASSWORD=
AGT_SOFTWARE_CERT=PENDENTE

# n8n (opcional, se tiveres um n8n acessível)
N8N_WEBHOOK_URL=

LOG_CHANNEL=stack
LOG_LEVEL=warning
